rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsTask() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function createsOwnTask() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow create: if createsOwnTask();
      allow read, update, delete: if ownsTask();
    }
  }
}

